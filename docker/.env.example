# PostgreSQL
PG_USER=scale
PG_PASSWORD=scalepass
PG_DB=scale_system

# API
API_PORT=8000
JWT_SECRET=change-me-to-a-real-secret-min-32-chars-prod
ALLOWED_ORIGINS=http://localhost:8080

# Web
WEB_PORT=8080
VITE_API_BASE_URL=/api/v1
# nginx /api 反代上游（compose 默认用 service 名 api:8000；Zeabur 改成内网域名）
API_UPSTREAM=api:8000
