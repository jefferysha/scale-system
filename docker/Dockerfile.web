# Scale Web · React 19 + Vite 6 → nginx 静态托管
# 多阶段：1) pnpm build 出 dist  2) nginx alpine 托管

FROM node:22-alpine AS builder

RUN corepack enable && corepack prepare pnpm@9.12.0 --activate

WORKDIR /build

# 1. 先 copy workspace 元数据让 pnpm 装依赖（layer cache 友好）
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml /build/
COPY apps/web/package.json /build/apps/web/
COPY packages/shared-types/package.json /build/packages/shared-types/
COPY apps/api/package.json /build/apps/api/
COPY apps/desktop/package.json /build/apps/desktop/

# 装依赖（仅 web + 其依赖）
RUN pnpm install --frozen-lockfile --filter @scale/web... --prod=false

# 2. copy 源码 + shared-types
COPY packages/shared-types /build/packages/shared-types
COPY apps/web /build/apps/web

# 注入生产 API 端点（compose 时通过 env 改）
ARG VITE_API_BASE_URL=/api/v1
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN pnpm --filter @scale/web build


# === 运行时 ===
FROM nginx:1.27-alpine AS runtime

# 自定义 nginx 配置：SPA fallback + /api 反代到 api 服务
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

COPY --from=builder /build/apps/web/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost/ >/dev/null 2>&1 || exit 1

CMD ["nginx", "-g", "daemon off;"]
